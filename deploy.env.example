# sam deploy 파라미터 (예시).
# 복사해서 deploy.env 로 만든 뒤 BOT_TOKEN을 채우세요. deploy.env는 커밋 금지.
#
# 사용법:
#   cp deploy.env.example deploy.env
#   # deploy.env 열어서 DISCORD_BOT_TOKEN 채우기
#   source deploy.env
#   sam build
#   sam deploy --guided \
#     --parameter-overrides \
#       DiscordPublicKey=$DISCORD_PUBLIC_KEY \
#       DiscordApplicationId=$DISCORD_APPLICATION_ID \
#       DiscordBotToken=$DISCORD_BOT_TOKEN

export DISCORD_APPLICATION_ID=1524603856460447754
export DISCORD_PUBLIC_KEY=3bfc60007f6d754d48181b99bded9820b8bb9af2ef6078d154fc942a51af1e48
export DISCORD_BOT_TOKEN=<여기에 Bot Token 붙여넣기 — 커밋 금지>
